<% content_for :title, "Leaderboard" %>

<div class="max-w-5xl mx-auto">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-black tracking-tight text-white">Leaderboard</h1>
    <p class="text-gray-400 text-sm mt-1"><%= @tournament.year %> NBA Play-In Tournament</p>
  </div>

  <% unless @any_locked %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 text-center text-gray-400">
      The leaderboard will appear once picks lock.
    </div>
  <% else %>

  <!-- Column headers: one per game -->
  <%
    col_labels = {
      ["East", Game::SEVEN_EIGHT] => { short: "E #7v8",   note: "2 pts", color: "text-green-400" },
      ["East", Game::NINE_TEN]    => { short: "E #9v10",  note: "2 pts", color: "text-yellow-400" },
      ["East", Game::FINAL]       => { short: "E Final",  note: "3 pts", color: "text-blue-400" },
      ["West", Game::SEVEN_EIGHT] => { short: "W #7v8",   note: "2 pts", color: "text-green-400" },
      ["West", Game::NINE_TEN]    => { short: "W #9v10",  note: "2 pts", color: "text-yellow-400" },
      ["West", Game::FINAL]       => { short: "W Final",  note: "3 pts", color: "text-blue-400" },
    }
  %>

  <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
    <table id="leaderboard-table" class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-800">
          <th class="text-left px-4 py-3 text-gray-400 font-semibold w-8">#</th>
          <th data-sort="player" class="text-left px-4 py-3 text-gray-400 font-semibold cursor-pointer hover:text-white select-none">Player <span class="sort-indicator"></span></th>
          <% @ordered_games.each do |game| %>
            <% meta = col_labels[[game.conference, game.game_type]] %>
            <th data-sort="game-<%= game.id %>" class="text-center px-3 py-3 font-semibold cursor-pointer hover:brightness-125 select-none">
              <div class="<%= meta[:color] %>"><%= meta[:short] %> <span class="sort-indicator"></span></div>
              <div class="text-gray-600 text-xs font-normal"><%= meta[:note] %></div>
            </th>
          <% end %>
          <th data-sort="score" class="text-center px-4 py-3 text-white font-bold cursor-pointer hover:text-orange-400 select-none">Pts <span class="sort-indicator"></span></th>
          <th data-sort="max-score" class="text-center px-4 py-3 text-gray-400 font-bold cursor-pointer hover:text-white select-none">Max <span class="sort-indicator"></span></th>
        </tr>
      </thead>
      <tbody>
        <% @rows.each_with_index do |row, i| %>
          <tr class="border-b border-gray-800/50 <%= row[:user] == Current.user ? 'bg-gray-800/40' : '' %>"
              data-player="<%= row[:user].display_name_or_email %>"
              data-score="<%= row[:score] %>"
              data-max-score="<%= row[:max_score] %>"
              <% @ordered_games.each do |game| %>
                data-game-<%= game.id %>="<%= row[:picks][game.id]&.picked_winner&.abbreviation || '' %>"
              <% end %>>
            <td class="rank-cell px-4 py-3 text-gray-500 text-xs"><%= i + 1 %></td>
            <td class="px-4 py-3 font-semibold text-white">
              <span class="relative group cursor-default">
                <%= row[:user].display_name_or_email %>
                <span class="absolute bottom-full left-0 mb-1 px-2 py-1 rounded bg-gray-700 text-gray-200 text-xs font-normal whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-100 pointer-events-none">
                  <%= row[:user].email_address %>
                </span>
              </span>
              <% if row[:user] == Current.user %>
                <span class="text-xs text-orange-400 ml-1">(you)</span>
              <% end %>
            </td>
            <% @ordered_games.each do |game| %>
              <% pick = row[:picks][game.id] %>
              <% team = pick&.picked_winner %>
              <td class="px-3 py-3 text-center">
                <% if team %>
                  <% impossible = row[:impossible_game_ids].include?(game.id) %>
                  <span class="inline-block px-2 py-0.5 rounded text-xs font-bold"
                        style="background-color: <%= team.primary_color %>; color: <%= team.secondary_color %>; border: 1.5px solid <%= team.primary_color %>40;">
                    <%= team.abbreviation %>
                  </span>
                  <% if pick.correct? %>
                    <span class="text-xs">✅</span>
                  <% elsif pick.incorrect? || impossible %>
                    <span class="text-xs">❌</span>
                  <% end %>
                <% else %>
                  <span class="text-gray-600">—</span>
                <% end %>
              </td>
            <% end %>
            <td class="px-4 py-3 text-center font-black text-lg text-white"><%= row[:score] %></td>
            <td class="px-4 py-3 text-center font-bold text-lg text-gray-400"><%= row[:max_score] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% end %>
</div>

<script>
  const table = document.getElementById("leaderboard-table");
  if (table) {
    let currentSort = { key: "max-score", dir: "desc" };

    function getVal(row, key) {
      const raw = row.dataset[key.replace(/-([a-z])/g, (_, c) => c.toUpperCase())] ?? row.dataset[key] ?? "";
      const num = parseFloat(raw);
      return isNaN(num) ? raw.toLowerCase() : num;
    }

    function sortTable(key, dir) {
      const tbody = table.querySelector("tbody");
      const rows = Array.from(tbody.querySelectorAll("tr"));
      rows.sort((a, b) => {
        const av = getVal(a, key), bv = getVal(b, key);
        if (av === bv) return 0;
        const cmp = av > bv ? 1 : -1;
        return dir === "asc" ? cmp : -cmp;
      });
      rows.forEach(r => tbody.appendChild(r));
      // Update rank numbers
      rows.forEach((r, i) => {
        const cell = r.querySelector(".rank-cell");
        if (cell) cell.textContent = i + 1;
      });
      // Update indicators
      table.querySelectorAll("th .sort-indicator").forEach(el => el.textContent = "");
      const activeHeader = table.querySelector(`th[data-sort="${key}"] .sort-indicator`);
      if (activeHeader) activeHeader.textContent = dir === "asc" ? " ↑" : " ↓";
    }

    table.querySelectorAll("th[data-sort]").forEach(th => {
      th.addEventListener("click", () => {
        const key = th.dataset.sort;
        const dir = currentSort.key === key && currentSort.dir === "desc" ? "asc" : "desc";
        currentSort = { key, dir };
        sortTable(key, dir);
      });
    });

    // Apply default sort indicator
    sortTable("max-score", "desc");
  }
</script>
