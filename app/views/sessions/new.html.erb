<div class="min-h-[80vh] flex items-center justify-center py-8">
  <div class="w-full max-w-sm flex flex-col gap-4">

    <!-- Option 1: Create Account (primary) -->
    <div class="bg-gray-900 border border-orange-500/40 rounded-2xl p-8">
      <div class="flex items-center gap-2 mb-1">
        <span class="bg-orange-500 text-white text-xs font-black px-2 py-0.5 rounded">NEW HERE?</span>
      </div>
      <h1 class="text-2xl font-black text-white mt-2 mb-1">Create an account</h1>
      <p class="text-sm text-gray-400 mb-6">Make your picks for the Play-In Tournament. Takes 10 seconds.</p>

      <% if @registration_user&.errors&.any? && !flash[:account_exists] %>
        <div class="py-2 px-3 bg-red-900/50 border border-red-700 mb-5 text-red-400 text-sm rounded-lg">
          <% @registration_user.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_with model: (@registration_user || User.new), url: registration_path do |form| %>
        <div class="mb-4">
          <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-400 mb-1" %>
          <%= form.email_field :email_address, required: true,
                autocomplete: "username",
                placeholder: "you@example.com",
                class: "block w-full rounded-lg border border-gray-700 bg-gray-800 text-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" %>
        </div>
        <div class="mb-4">
          <%= form.label :password, "Password", class: "block text-sm font-medium text-gray-400 mb-1" %>
          <%= form.password_field :password, required: true,
                autocomplete: "new-password",
                placeholder: "Choose a password",
                maxlength: 72,
                class: "block w-full rounded-lg border border-gray-700 bg-gray-800 text-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" %>
        </div>
        <div class="mb-6">
          <%= form.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-400 mb-1" %>
          <%= form.password_field :password_confirmation, required: true,
                autocomplete: "new-password",
                placeholder: "Confirm your password",
                maxlength: 72,
                class: "block w-full rounded-lg border border-gray-700 bg-gray-800 text-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" %>
        </div>
        <%= form.submit "Create account →", class: "w-full bg-orange-500 hover:bg-orange-400 text-white font-bold py-2.5 rounded-lg cursor-pointer transition-colors" %>
        <% if flash[:account_exists] %>
          <p class="mt-3 text-sm text-yellow-300 text-center">An account with this email already exists. Sign in below ↓</p>
        <% end %>
      <% end %>
    </div>

    <!-- Divider -->
    <div class="flex items-center gap-3">
      <div class="flex-1 h-px bg-gray-800"></div>
      <span class="text-xs text-gray-600 uppercase tracking-widest">Already have an account?</span>
      <div class="flex-1 h-px bg-gray-800"></div>
    </div>

    <!-- Option 2: Sign In (secondary) -->
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8">
      <h2 class="text-xl font-black text-white mb-5">Sign in</h2>

      <% if alert = flash[:alert] %>
        <p class="py-2 px-3 bg-red-900/50 border border-red-700 mb-5 text-red-400 font-medium rounded-lg text-sm"><%= alert %></p>
      <% end %>

      <%= form_with url: session_url do |form| %>
        <div class="mb-4">
          <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-400 mb-1" %>
          <%= form.email_field :email_address, required: true,
                autocomplete: "username",
                placeholder: "you@example.com",
                value: params[:email_address],
                class: "block w-full rounded-lg border border-gray-700 bg-gray-800 text-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" %>
        </div>
        <div class="mb-6">
          <%= form.label :password, "Password", class: "block text-sm font-medium text-gray-400 mb-1" %>
          <%= form.password_field :password, required: true,
                autocomplete: "current-password",
                placeholder: "••••••••",
                maxlength: 72,
                class: "block w-full rounded-lg border border-gray-700 bg-gray-800 text-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" %>
        </div>
        <div class="flex items-center gap-4">
          <%= form.submit "Sign in", class: "flex-1 bg-gray-700 hover:bg-gray-600 text-white font-bold py-2.5 rounded-lg cursor-pointer transition-colors text-center" %>
          <%= link_to "Forgot password?", new_password_path, class: "text-sm text-gray-500 hover:text-gray-300" %>
        </div>
      <% end %>
    </div>

  </div>
</div>
