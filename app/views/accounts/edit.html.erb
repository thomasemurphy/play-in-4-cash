<% content_for :title, "Account" %>

<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8">
      <h1 class="text-2xl font-black text-white mb-1">Account</h1>
      <p class="text-sm text-gray-400 mb-6"><%= Current.user.email_address %></p>

      <% if notice = flash[:notice] %>
        <p class="py-2 px-3 bg-green-900/50 border border-green-700 mb-5 text-green-400 font-medium rounded-lg text-sm"><%= notice %></p>
      <% end %>

      <%= form_with model: Current.user, url: account_path, method: :patch do |form| %>
        <div class="mb-6">
          <%= form.label :display_name, "Display name", class: "block text-sm font-medium text-gray-400 mb-1" %>
          <%= form.text_field :display_name,
                placeholder: Current.user.email_address.split("@").first,
                value: Current.user.display_name,
                maxlength: 32,
                class: "block w-full rounded-lg border border-gray-700 bg-gray-800 text-white px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" %>
          <p class="text-xs text-gray-600 mt-1">This is how your name appears on the leaderboard.</p>
        </div>

        <%= form.submit "Save", class: "w-full bg-orange-500 hover:bg-orange-400 text-white font-bold py-2.5 rounded-lg cursor-pointer transition-colors" %>
      <% end %>
    </div>
  </div>
</div>
