<% content_for :title, "Admin — Users" %>

<div class="max-w-2xl mx-auto">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-black tracking-tight text-white">Admin</h1>
    <p class="text-gray-400 text-sm mt-1">Registered users</p>
  </div>

  <%= render "admin/shared/tabs" %>

  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 mb-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-sm font-semibold text-gray-400"><%= @users.count %> users — all email addresses</span>
      <button onclick="copyEmails()" class="text-xs bg-gray-700 hover:bg-gray-600 text-white font-semibold px-3 py-1.5 rounded-lg transition-colors cursor-pointer">
        Copy all
      </button>
    </div>
    <textarea id="email-list" readonly
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-300 font-mono resize-none focus:outline-none focus:ring-1 focus:ring-orange-500"
              rows="4"><%= @users.map(&:email_address).join(", ") %></textarea>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
    <div class="grid px-4 py-3 border-b border-gray-800 text-xs font-semibold text-gray-400 uppercase tracking-wider"
         style="grid-template-columns: 1fr 1fr auto">
      <div>Email</div>
      <div>Display name</div>
      <div>Joined</div>
    </div>
    <% @users.each do |user| %>
      <div class="grid px-4 py-3 border-b border-gray-800/50 text-sm items-center"
           style="grid-template-columns: 1fr 1fr auto">
        <div class="text-white truncate"><%= user.email_address %></div>
        <div class="text-gray-400 truncate"><%= user.display_name.presence || "—" %></div>
        <div class="text-gray-600 text-xs whitespace-nowrap"><%= user.created_at.strftime("%b %-d") %></div>
      </div>
    <% end %>
  </div>
</div>

<script>
  function copyEmails() {
    const textarea = document.getElementById("email-list");
    navigator.clipboard.writeText(textarea.value).then(() => {
      const btn = event.target;
      btn.textContent = "Copied!";
      setTimeout(() => btn.textContent = "Copy all", 2000);
    });
  }
</script>
