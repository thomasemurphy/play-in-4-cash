<% content_for :title, "Admin — Picks" %>

<div class="max-w-6xl mx-auto">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-black tracking-tight text-white">Admin</h1>
    <p class="text-gray-400 text-sm mt-1">Manually enter or edit anyone's picks</p>
  </div>

  <%= render "admin/shared/tabs" %>

  <% if flash[:notice] %>
    <p class="mb-4 px-4 py-2 bg-green-900/50 border border-green-700 text-green-400 rounded-lg text-sm"><%= flash[:notice] %></p>
  <% end %>

  <%
    col_labels = {
      ["East", Game::SEVEN_EIGHT] => "E #7v8",
      ["East", Game::NINE_TEN]    => "E #9v10",
      ["East", Game::FINAL]       => "E Final",
      ["West", Game::SEVEN_EIGHT] => "W #7v8",
      ["West", Game::NINE_TEN]    => "W #9v10",
      ["West", Game::FINAL]       => "W Final",
    }
  %>

  <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-x-auto">

    <!-- Header row -->
    <div class="grid gap-2 px-4 py-3 border-b border-gray-800 text-xs font-semibold text-gray-400 uppercase tracking-wider"
         style="grid-template-columns: 180px repeat(6, 1fr) auto">
      <div>Player</div>
      <% @ordered_games.each do |game| %>
        <div class="text-center"><%= col_labels[[game.conference, game.game_type]] %></div>
      <% end %>
      <div></div>
    </div>

    <!-- One form per user row -->
    <% @users.each do |row| %>
      <%= form_with url: upsert_admin_picks_path, method: :patch,
            class: "grid gap-2 px-4 py-2 border-b border-gray-800/50 hover:bg-gray-800/30 items-center",
            style: "grid-template-columns: 180px repeat(6, 1fr) auto" do |f| %>

        <%= f.hidden_field :user_id, value: row[:user].id %>

        <div class="font-semibold text-white text-sm truncate" title="<%= row[:user].email_address %>">
          <%= row[:user].display_name_or_email %>
        </div>

        <% @ordered_games.each do |game| %>
          <% pick = row[:picks][game.id] %>
          <% teams = game.game_type == Game::FINAL ? @teams_by_conference[game.conference] : [game.home_team, game.away_team] %>
          <select name="picks[<%= game.id %>]"
                  class="bg-gray-800 border border-gray-700 rounded-lg px-2 py-1.5 text-xs text-white focus:outline-none focus:ring-1 focus:ring-orange-500 w-full">
            <option value="">—</option>
            <% teams.each do |team| %>
              <option value="<%= team.id %>" <%= pick&.picked_winner_id == team.id ? "selected" : "" %>>
                <%= team.abbreviation %>
              </option>
            <% end %>
          </select>
        <% end %>

        <%= f.submit "Save", class: "bg-orange-500 hover:bg-orange-400 text-white font-bold px-3 py-1.5 rounded-lg cursor-pointer transition-colors text-xs whitespace-nowrap" %>

      <% end %>
    <% end %>

  </div>

  <div class="mt-6 text-center">
    <%= link_to "View leaderboard →", leaderboard_path, class: "text-orange-400 hover:text-orange-300 text-sm font-semibold" %>
  </div>
</div>
