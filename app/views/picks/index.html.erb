<% content_for :title, "#{@tournament.year} NBA Play-In Bracket" %>

<div class="max-w-4xl mx-auto"
     data-controller="bracket"
     data-bracket-picks-url-value="<%= picks_path %>"
     data-bracket-picks-value="<%= @picks.transform_values { |p| p.picked_winner_id }.to_json %>"
     data-bracket-east-lock-time-value="<%= @tournament.east_lock_time.utc.iso8601 %>"
     data-bracket-west-lock-time-value="<%= @tournament.west_lock_time.utc.iso8601 %>">

  <div class="text-center mb-10">
    <h1 class="text-3xl font-black tracking-tight text-white"><%= @tournament.year %> NBA Play-In Tournament</h1>
  </div>

  <div class="flex flex-col gap-8">
    <% %w[East West].each do |conference| %>
      <%
        seven_eight_game = @games.find { |g| g.conference == conference && g.game_type == Game::SEVEN_EIGHT }
        nine_ten_game    = @games.find { |g| g.conference == conference && g.game_type == Game::NINE_TEN }
        final_game       = @games.find { |g| g.conference == conference && g.game_type == Game::FINAL }
      %>

      <div class="bg-gray-900 rounded-2xl p-6 border border-gray-800"
           data-conference="<%= conference %>">

        <h2 class="text-lg font-bold text-orange-400 mb-1 uppercase tracking-widest text-center">
          <%= conference %>ern Conference
        </h2>
        <p class="text-xs text-center mb-6 text-gray-500"
           data-bracket-lock-label-conference="<%= conference %>"></p>

        <div class="grid grid-cols-2 gap-6 items-center">

          <!-- Left column: 7v8 stacked on top of 9v10 -->
          <div class="flex flex-col gap-4">

            <!-- Game 1: #7 vs #8 -->
            <div>
              <div class="text-xs text-gray-500 font-semibold uppercase tracking-wider text-center mb-2">
                #7 vs #8 &bull; <span class="text-green-400">Winner → #7 Seed</span>
              </div>
              <%= render "game_card",
                    game: seven_eight_game,
                    picks: @picks,
                    data_attrs: {
                      "data-bracket-game-type": Game::SEVEN_EIGHT,
                      "data-bracket-conference": conference
                    } %>
            </div>

            <!-- Game 2: #9 vs #10 -->
            <div>
              <div class="text-xs text-gray-500 font-semibold uppercase tracking-wider text-center mb-2">
                #9 vs #10 &bull; <span class="text-yellow-400">Winner Advances</span>
              </div>
              <%= render "game_card",
                    game: nine_ten_game,
                    picks: @picks,
                    data_attrs: {
                      "data-bracket-game-type": Game::NINE_TEN,
                      "data-bracket-conference": conference
                    } %>
            </div>
          </div>

          <!-- Right column: Play-In Final -->
          <div>
            <div class="text-xs text-gray-500 font-semibold uppercase tracking-wider text-center mb-2">
              Play-In Final &bull; <span class="text-blue-400">Winner → #8 Seed</span>
            </div>
            <div data-bracket-final-target-conference="<%= conference %>">
              <%= render "final_game_card",
                    game: final_game,
                    picks: @picks,
                    seven_eight_game: seven_eight_game,
                    nine_ten_game: nine_ten_game,
                    conference: conference %>
            </div>
          </div>

        </div>
      </div>
    <% end %>
  </div>

</div>
