<%# Renders a game card with two team buttons the user can click to pick a winner.
    Locals: game (Game), picks (Hash of game_id => UserPick), data_attrs (Hash) %>

<% pick = picks[game.id] %>
<% picked_winner_id = pick&.picked_winner_id %>

<div class="rounded-xl border border-gray-700 overflow-hidden"
     data-bracket-game-id="<%= game.id %>"
     data-bracket-game-type-value="<%= game.game_type %>"
     data-bracket-conference-value="<%= game.conference %>"
     <%= data_attrs.map { |k, v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>>

  <!-- Home Team -->
  <% home_selected = picked_winner_id == game.home_team_id %>
  <button type="button"
          class="team-pick-btn w-full flex items-center gap-3 px-4 py-3 transition-all duration-150 text-left font-bold
                 <%= home_selected ? '' : 'bg-gray-800 hover:bg-gray-700 text-gray-200' %>"
          style="<%= home_selected ? "background-color: #{game.home_team.primary_color}; color: #{game.home_team.secondary_color};" : '' %>"
          data-action="click->bracket#pickWinner"
          data-bracket-game-id-param="<%= game.id %>"
          data-bracket-winner-id-param="<%= game.home_team_id %>"
          data-bracket-conference-param="<%= game.conference %>"
          data-bracket-game-type-param="<%= game.game_type %>"
          data-bracket-home-away-param="home"
          data-team-color="<%= game.home_team.primary_color %>"
          data-team-secondary-color="<%= game.home_team.secondary_color %>">
    <span class="text-xs font-bold w-4">#<%= game.home_team.seed %></span>
    <span class="font-semibold text-sm"><%= game.home_team.name %></span>
  </button>

  <div class="h-px bg-gray-700 mx-4"></div>

  <!-- Away Team -->
  <% away_selected = picked_winner_id == game.away_team_id %>
  <button type="button"
          class="team-pick-btn w-full flex items-center gap-3 px-4 py-3 transition-all duration-150 text-left font-bold
                 <%= away_selected ? '' : 'bg-gray-800 hover:bg-gray-700 text-gray-200' %>"
          style="<%= away_selected ? "background-color: #{game.away_team.primary_color}; color: #{game.away_team.secondary_color};" : '' %>"
          data-action="click->bracket#pickWinner"
          data-bracket-game-id-param="<%= game.id %>"
          data-bracket-winner-id-param="<%= game.away_team_id %>"
          data-bracket-conference-param="<%= game.conference %>"
          data-bracket-game-type-param="<%= game.game_type %>"
          data-bracket-home-away-param="away"
          data-team-color="<%= game.away_team.primary_color %>"
          data-team-secondary-color="<%= game.away_team.secondary_color %>">
    <span class="text-xs font-bold w-4">#<%= game.away_team.seed %></span>
    <span class="font-semibold text-sm"><%= game.away_team.name %></span>
  </button>

</div>
